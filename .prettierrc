{
    "semi": false,
    "endOfLine": "lf",
    "singleQuote": true,
    "trailingComma": "all",
    "singleAttributePerLine": true,
    "plugins": ["prettier-plugin-blade", "prettier-plugin-tailwindcss"],
    "overrides": [
        {
            "files": ["*.blade.php"],
            "options": {
                "parser": "blade",
                "singleAttributePerLine": false
            }
        },
        {
            "files": ["*.js", "*.json", "*.css", "*.yml"],
            "options": {
                "singleAttributePerLine": true
            }
        }
    ]
}
