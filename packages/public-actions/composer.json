{
    "name": "capell-app/public-actions",
    "description": "Reusable public submit actions, outbound automation dispatch, and integration endpoints for Capell CMS.",
    "type": "library",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "Capell\\PublicActions\\": "src/",
            "Capell\\PublicActions\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\PublicActions\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\PublicActions\\Providers\\PublicActionsServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0",
        "capell-app/core": "^4.0",
        "capell-app/frontend": "^4.0",
        "laravel/framework": "^11.45.3|^12.41.1|^13.0",
        "lorisleiva/laravel-actions": "^2.8"
    },
    "require-dev": {
        "orchestra/testbench": "^9.15|^10.8|^11.0",
        "pestphp/pest": "^3.8|^4.3",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "pest --colors=always"
    }
}
