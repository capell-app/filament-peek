{
    "manifest-version": 2,
    "name": "capell-app/wordpress-importer",
    "kind": "package",
    "capell-version": "^4.0",
    "productGroup": "Capell Operations",
    "tier": "premium",
    "bundle": "operations",
    "description": "WordPress Importer adds WordPress WXR XML parsing to the Capell MigrationAssistant workflow.",
    "surfaces": ["admin", "console"],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/core",
            "capell-app/migration-assistant"
        ],
        "optional": [],
        "conflicts": []
    },
    "lifecycle": {
        "activation": "manual",
        "defaultStatus": "available",
        "requiresInstallCommand": false
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\WordPressImporter\\Providers\\WordPressImporterServiceProvider"
        ],
        "admin": [],
        "frontend": []
    },
    "database": {
        "migrations": false,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "setupParams": [],
        "demo": null,
        "demoParams": [],
        "health": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [],
    "assets": [],
    "healthChecks": []
}
