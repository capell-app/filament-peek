{
    "name": "capell-app/api",
    "description": "Public JSON delivery of published Capell page data",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "capell-app/core": "^4.0 || 4.x-dev",
        "capell-app/layout-builder": "^4.0 || 4.x-dev",
        "spatie/laravel-package-tools": "^1.14.1",
        "symfony/html-sanitizer": "^7.0|^8.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.15|^10.8|^11.0",
        "pestphp/pest": "^3.0|^4.1",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\Api\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Api\\Providers\\ApiServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "homepage": "https://github.com/capell-app/api",
    "keywords": [
        "capell",
        "cms",
        "laravel",
        "api",
        "json"
    ],
    "authors": [
        {
            "name": "Capell Team",
            "email": "team@capell.app",
            "role": "Developer"
        }
    ],
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/api"
    }
}
