{
    "manifest-version": 2,
    "name": "capell-app/insights",
    "kind": "package",
    "capell-version": "^4.0",
    "productGroup": "Capell Growth",
    "tier": "premium",
    "bundle": "growth",
    "description": "Insights records first-party visits, events, consent decisions, page views, clicks, and journey data for Capell sites.",
    "surfaces": [
        "admin",
        "frontend"
    ],
    "dependencies": {
        "requires": [
            "capell-app/core",
            "capell-app/admin",
            "capell-app/frontend"
        ],
        "optional": [],
        "conflicts": []
    },
    "lifecycle": {
        "activation": "manual",
        "defaultStatus": "available",
        "requiresInstallCommand": false
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\Insights\\Providers\\InsightsServiceProvider"
        ],
        "admin": [
            "Capell\\Insights\\Providers\\AdminServiceProvider"
        ],
        "frontend": []
    },
    "database": {
        "migrations": true,
        "settings": true,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "setupParams": [],
        "demo": null,
        "demoParams": [],
        "health": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [],
    "assets": [],
    "healthChecks": []
}
