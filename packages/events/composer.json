{
    "name": "capell-app/events",
    "description": "Events for Capell",
    "keywords": [
        "capell",
        "events",
        "calendar",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/events",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "capell-app/frontend": "*",
        "capell-app/layout-builder": "*",
        "capell-app/navigation": "*",
        "capell-app/publishing-studio": "*",
        "rlanvin/php-rrule": "^2.6",
        "spatie/icalendar-generator": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Events\\": "src/",
            "Capell\\Events\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Events\\Providers\\EventsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
