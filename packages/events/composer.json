{
    "name": "capell-app/events",
    "description": "Events for Capell",
    "keywords": [
        "capell",
        "events",
        "calendar",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/events",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0 || 4.x-dev",
        "capell-app/frontend": "^4.0 || 4.x-dev",
        "capell-app/navigation": "^4.0 || 4.x-dev",
        "capell-app/publishing-studio": "^4.0 || 4.x-dev",
        "rlanvin/php-rrule": "^2.6",
        "spatie/icalendar-generator": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Events\\": "src/",
            "Capell\\Events\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Events\\Providers\\EventsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "type": "library",
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/events"
    }
}
