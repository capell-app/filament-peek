{
    "name": "capell-app/content-sections",
    "description": "Reusable content sections for Capell",
    "keywords": [
        "capell",
        "content-sections",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/content-sections",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0 || 4.x-dev",
        "capell-app/content-blocks": "^4.0 || 4.x-dev",
        "capell-app/core": "^4.0 || 4.x-dev",
        "capell-app/frontend": "^4.0 || 4.x-dev",
        "capell-app/layout-builder": "^4.0 || 4.x-dev"
    },
    "suggest": {
        "capell-app/public-actions": "Enables CMS action buttons that submit reusable public actions.",
        "capell-app/publishing-studio": "Enables workspace-aware section publishing integration."
    },
    "autoload": {
        "psr-4": {
            "Capell\\ContentSections\\": "src/",
            "Capell\\ContentSections\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\ContentSections\\Providers\\ContentSectionsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "type": "library",
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/content-sections"
    }
}
