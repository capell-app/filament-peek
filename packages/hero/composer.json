{
    "name": "capell-app/hero",
    "description": "Hero block rendering and default home hero setup for Capell.",
    "keywords": [
        "capell",
        "hero",
        "laravel",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/hero",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "capell-app/core": "^4.0 || 4.x-dev",
        "capell-app/frontend": "^4.0 || 4.x-dev",
        "capell-app/layout-builder": "^4.0 || 4.x-dev",
        "lorisleiva/laravel-actions": "^2.8",
        "spatie/laravel-package-tools": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Hero\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Hero\\Providers\\HeroServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "type": "library",
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/hero"
    }
}
