{
    "name": "capell-app/hero",
    "description": "Hero widget rendering and default home hero setup for Capell.",
    "keywords": [
        "capell",
        "hero",
        "laravel",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/hero",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "capell-app/core": "*",
        "capell-app/frontend": "*",
        "lorisleiva/laravel-actions": "^2.8",
        "spatie/laravel-package-tools": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Hero\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Hero\\Providers\\HeroServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
