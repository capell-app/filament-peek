{
    "name": "capell-app/diagnostics",
    "description": "Developer and operational diagnostics for Capell CMS.",
    "type": "library",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "Capell\\Diagnostics\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\Diagnostics\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Diagnostics\\Providers\\DiagnosticsServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0",
        "capell-app/core": "^4.0",
        "capell-app/html-cache": "^4.0 || 4.x-dev",
        "lorisleiva/laravel-actions": "^2.8",
        "spatie/laravel-data": "^4.5"
    },
    "homepage": "https://github.com/capell-app/diagnostics",
    "keywords": [
        "capell",
        "cms",
        "laravel",
        "diagnostics"
    ],
    "authors": [
        {
            "name": "Capell Team",
            "email": "team@capell.app",
            "role": "Developer"
        }
    ],
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/diagnostics"
    }
}
