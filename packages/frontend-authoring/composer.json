{
    "name": "capell-app/frontend-authoring",
    "description": "Frontend authoring bridge and in-page editing for Capell frontend",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0 || 4.x-dev",
        "capell-app/frontend": "^4.0 || 4.x-dev",
        "capell-app/html-cache": "^4.0 || 4.x-dev",
        "spatie/laravel-package-tools": "^1.14"
    },
    "autoload": {
        "psr-4": {
            "Capell\\FrontendAuthoring\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\FrontendAuthoring\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\FrontendAuthoring\\Providers\\FrontendAuthoringServiceProvider"
            ]
        }
    },
    "homepage": "https://github.com/capell-app/frontend-authoring",
    "keywords": [
        "capell",
        "cms",
        "laravel",
        "authoring",
        "frontend"
    ],
    "authors": [
        {
            "name": "Capell Team",
            "email": "team@capell.app",
            "role": "Developer"
        }
    ],
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/frontend-authoring"
    }
}
