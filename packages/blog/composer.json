{
    "name": "capell-app/blog",
    "description": "Blog for Capell",
    "keywords": [
        "capell",
        "blog",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/blog",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0 || 4.x-dev",
        "capell-app/content-sections": "^4.0 || 4.x-dev",
        "capell-app/demo-kit": "^4.0 || 4.x-dev",
        "capell-app/insights": "^4.0 || 4.x-dev",
        "capell-app/frontend": "^4.0 || 4.x-dev",
        "capell-app/html-cache": "^4.0 || 4.x-dev",
        "capell-app/layout-builder": "^4.0 || 4.x-dev",
        "capell-app/navigation": "^4.0 || 4.x-dev",
        "capell-app/site-discovery": "^4.0 || 4.x-dev",
        "capell-app/tags": "^4.0 || 4.x-dev",
        "capell-app/publishing-studio": "^4.0 || 4.x-dev"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Blog\\": "src/",
            "Capell\\Blog\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Blog\\Providers\\BlogServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "type": "library",
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/blog"
    }
}
