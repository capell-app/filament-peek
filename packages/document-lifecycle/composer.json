{
    "name": "capell-app/document-lifecycle",
    "description": "Controlled document registry, publication metadata, hashes, and acceptance evidence for Capell",
    "keywords": [
        "capell",
        "document-lifecycle",
        "legal",
        "governance",
        "publishing",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/document-lifecycle",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0 || 4.x-dev",
        "capell-app/core": "^4.0 || 4.x-dev",
        "capell-app/publishing-studio": "^4.0 || 4.x-dev"
    },
    "autoload": {
        "psr-4": {
            "Capell\\DocumentLifecycle\\": "src/",
            "Capell\\DocumentLifecycle\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\DocumentLifecycle\\Providers\\DocumentLifecycleServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "type": "library",
    "authors": [
        {
            "name": "Capell Team",
            "email": "team@capell.app",
            "role": "Developer"
        }
    ],
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/document-lifecycle"
    }
}
