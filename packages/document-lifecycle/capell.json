{
    "manifest-version": 3,
    "name": "capell-app/document-lifecycle",
    "slug": "document-lifecycle",
    "displayName": "Document Lifecycle",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Controlled document registry, publication metadata, hashes, and acceptance evidence for Capell CMS.",
    "product": {
        "group": "Capell Operations",
        "tier": "premium",
        "bundle": "operations"
    },
    "namespace": "Capell\\DocumentLifecycle",
    "surfaces": [
        "admin",
        "console"
    ],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/core",
            "capell-app/publishing-studio"
        ],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [
            "Capell\\DocumentLifecycle\\Providers\\DocumentLifecycleServiceProvider"
        ],
        "runtime": [],
        "admin": [
            "Capell\\DocumentLifecycle\\Providers\\DocumentLifecycleServiceProvider"
        ],
        "frontend": []
    },
    "contributes": [
        {
            "type": "admin-resource",
            "class": "Capell\\DocumentLifecycle\\Manifest\\DocumentResourceContribution",
            "resourceClass": "Capell\\DocumentLifecycle\\Filament\\Resources\\Documents\\DocumentResource",
            "group": "Document"
        }
    ],
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": [
            "document_lifecycle_documents",
            "document_lifecycle_publications",
            "legal_acceptances"
        ]
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [
        "ViewAny:Document",
        "View:Document",
        "Create:Document",
        "Update:Document",
        "Delete:Document",
        "DeleteAny:Document",
        "Restore:Document",
        "ForceDelete:Document",
        "Replicate:Document",
        "Reorder:Document"
    ],
    "capabilities": [
        "document-lifecycle",
        "document-lifecycle-admin",
        "document-lifecycle-acceptance"
    ],
    "performance": {
        "frontendRenderBudgetMs": 0,
        "adminQueryBudget": 40,
        "cacheTags": [],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": [],
            "sensitiveOutput": true,
            "invalidationSources": [],
            "queueInvalidation": false
        }
    },
    "healthChecks": [
        {
            "key": "document-lifecycle.package-health",
            "label": "Document Lifecycle package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\DocumentLifecycle\\Health\\DocumentLifecycleHealthCheck",
            "severity": "critical",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "paid",
        "requestedCertification": "first-party",
        "supportPolicy": "priority",
        "privateDocsRequested": true
    },
    "marketplace": {
        "summary": "Controlled document registry, publication metadata, hashes, and acceptance evidence for Capell CMS.",
        "screenshots": [
            {
                "path": "docs/assets/marketplace/extension-card.jpg",
                "alt": "Document Lifecycle extension preview image",
                "caption": "Document Lifecycle extension preview"
            }
        ],
        "categories": [
            "admin",
            "console",
            "operations"
        ]
    },
    "contributionTraceability": {
        "deferredContributions": [
            "model",
            "migration"
        ]
    }
}
