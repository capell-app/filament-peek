{
    "name": "capell-app/demo-kit",
    "description": "Demo content and media kit for Capell",
    "keywords": [
        "capell",
        "demo",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/demo-kit",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0 || 4.x-dev",
        "capell-app/core": "^4.0 || 4.x-dev",
        "capell-app/frontend": "^4.0 || 4.x-dev",
        "fakerphp/faker": "^1.24.1"
    },
    "autoload": {
        "psr-4": {
            "Capell\\DemoKit\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\DemoKit\\Providers\\DemoKitServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "type": "library",
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/demo-kit"
    }
}
