{
    "name": "capell-app/notes",
    "description": "Contextual notes, assignments, mentions, and reminders for Capell",
    "keywords": [
        "capell",
        "notes",
        "reminders",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/notes",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Notes\\": "src/",
            "Capell\\Notes\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Notes\\Providers\\NotesServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
