{
    "name": "capell-app/notes",
    "description": "Contextual notes, assignments, mentions, and reminders for Capell",
    "keywords": [
        "capell",
        "notes",
        "reminders",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/notes",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0 || 4.x-dev"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Notes\\": "src/",
            "Capell\\Notes\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Notes\\Providers\\NotesServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "type": "library",
    "authors": [
        {
            "name": "Capell Team",
            "email": "team@capell.app",
            "role": "Developer"
        }
    ],
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/notes"
    }
}
