{
    "manifest-version": 2,
    "name": "capell-app/publishing-studio",
    "kind": "package",
    "capell-version": "^4.0",
    "productGroup": "Capell Publishing Pro",
    "tier": "premium",
    "bundle": "publishing-pro",
    "description": "PublishingStudio provides preview, compare, approve, schedule, publish, restore, and rollback workflows for Capell content.",
    "surfaces": [
        "admin",
        "console"
    ],
    "dependencies": {
        "requires": [
            "capell-app/core",
            "capell-app/admin"
        ],
        "optional": [],
        "conflicts": []
    },
    "lifecycle": {
        "activation": "manual",
        "defaultStatus": "available",
        "requiresInstallCommand": false
    },
    "providers": {
        "metadata": [],
        "install": [
            "Capell\\PublishingStudio\\Providers\\ConsoleServiceProvider"
        ],
        "runtime": [
            "Capell\\PublishingStudio\\Providers\\PublishingStudioServiceProvider"
        ],
        "admin": [
            "Capell\\PublishingStudio\\Providers\\AdminServiceProvider"
        ],
        "frontend": []
    },
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": [
            "workspaces"
        ]
    },
    "commands": {
        "install": null,
        "setup": null,
        "setupParams": [],
        "demo": null,
        "demoParams": [],
        "health": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [
        "editorial-timeline",
        "live-preview",
        "preview-link-management",
        "content-compare",
        "approval-history",
        "review-assignments",
        "field-comments",
        "publish-readiness",
        "dry-run-validation",
        "release-window-guards",
        "url-collision-checks",
        "scheduled-publishing",
        "embargo-windows",
        "review-reminders",
        "version-history",
        "rollback-restore",
        "entity-restore",
        "activity-history",
        "stale-draft-management",
        "recovery-imports",
        "workspace-pruning",
        "load-testing"
    ],
    "assets": [],
    "healthChecks": [],
    "marketing": {
        "headline": "Editorial timeline workflow for Capell",
        "summary": "Preview, compare, comment, assign reviewers, approve, validate, schedule, publish, restore, and rollback Capell content through a premium workflow layer with live preview, review history, readiness checks, version history, and recovery surfaces.",
        "positioning": "Capell's flagship publishing workflow, designed to give editorial teams a Statamic-style content history experience while remaining a separate premium package."
    },
    "screenshots": "docs/screenshots.json"
}
