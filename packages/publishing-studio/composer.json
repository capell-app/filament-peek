{
    "name": "capell-app/publishing-studio",
    "description": "Editorial workflow package for Capell revisions, scheduling, approvals, and controlled publishing",
    "keywords": [
        "capell",
        "publishing-studio",
        "revisions",
        "scheduling",
        "approvals",
        "editorial-workflow",
        "laravel",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/publishing-studio",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0 || 4.x-dev",
        "capell-app/migration-assistant": "^4.0 || 4.x-dev",
        "capell-app/core": "^4.0 || 4.x-dev",
        "capell-app/html-cache": "^4.0 || 4.x-dev",
        "capell-app/navigation": "^4.0 || 4.x-dev",
        "jfcherng/php-diff": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\PublishingStudio\\": "src/",
            "Capell\\PublishingStudio\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\PublishingStudio\\Providers\\PublishingStudioServiceProvider",
                "Capell\\PublishingStudio\\Providers\\ConsoleServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "type": "library",
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/publishing-studio"
    }
}
