{
    "manifest-version": 2,
    "name": "capell-app/newsletter",
    "kind": "package",
    "capell-version": "^4.0",
    "productGroup": "Capell Marketing",
    "tier": "premium",
    "bundle": "newsletter",
    "description": "Newsletter adds subscriber capture and audience workflows for Capell sites.",
    "surfaces": [
        "admin",
        "frontend"
    ],
    "dependencies": {
        "requires": [
            "capell-app/core",
            "capell-app/admin",
            "capell-app/frontend",
            "capell-app/form-builder",
            "capell-app/tags"
        ],
        "optional": [],
        "conflicts": []
    },
    "lifecycle": {
        "activation": "manual",
        "defaultStatus": "available",
        "requiresInstallCommand": false
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\Newsletter\\Providers\\NewsletterServiceProvider"
        ],
        "admin": [
            "Capell\\Newsletter\\Providers\\AdminServiceProvider"
        ],
        "frontend": []
    },
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "setupParams": [],
        "demo": null,
        "demoParams": [],
        "health": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [],
    "assets": [],
    "healthChecks": []
}
