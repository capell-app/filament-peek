{
    "name": "capell-app/tags",
    "description": "Tags for Capell",
    "keywords": [
        "capell",
        "tags",
        "laravel",
        "filamentphp"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0 || 4.x-dev",
        "capell-app/navigation": "^4.0 || 4.x-dev",
        "capell-app/publishing-studio": "^4.0 || 4.x-dev",
        "filament/spatie-laravel-tags-plugin": "^4.0|^5.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Tags\\": "src/",
            "Capell\\Tags\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Tags\\Providers\\TagsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "type": "library",
    "homepage": "https://github.com/capell-app/tags",
    "authors": [
        {
            "name": "Capell Team",
            "email": "team@capell.app",
            "role": "Developer"
        }
    ],
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/tags"
    }
}
