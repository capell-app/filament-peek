{
    "name": "capell-app/ai-orchestrator",
    "description": "Capell AIOrchestrator orchestration package",
    "keywords": [
        "capell",
        "ai-orchestrator",
        "ai"
    ],
    "homepage": "https://capell.app",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0 || 4.x-dev",
        "capell-app/core": "^4.0 || 4.x-dev",
        "capell-app/layout-builder": "^4.0 || 4.x-dev",
        "lorisleiva/laravel-actions": "^2.8",
        "spatie/laravel-data": "^4.5",
        "spatie/laravel-package-tools": "^1.14.1"
    },
    "autoload": {
        "psr-4": {
            "Capell\\AIOrchestrator\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\AIOrchestrator\\Providers\\AIOrchestratorServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "type": "library",
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/ai-orchestrator"
    }
}
