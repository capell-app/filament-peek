{
    "name": "capell-app/login-audit",
    "description": "Authentication log for Capell",
    "keywords": [
        "capell",
        "login-audit",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/login-audit",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0 || 4.x-dev",
        "rappasoft/laravel-authentication-log": "^6.0|^5.0",
        "tapp/filament-authentication-log": "^4.0|^5.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\LoginAudit\\": "src/",
            "Capell\\LoginAudit\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\LoginAudit\\Providers\\LoginAuditServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "type": "library",
    "authors": [
        {
            "name": "Capell Team",
            "email": "team@capell.app",
            "role": "Developer"
        }
    ],
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/login-audit"
    }
}
