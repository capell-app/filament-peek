{
    "manifest-version": 2,
    "name": "capell-app/email-studio",
    "kind": "package",
    "capell-version": "^4.0",
    "productGroup": "Capell Communications",
    "tier": "premium",
    "bundle": "communications",
    "description": "Email Studio gives Capell a transactional email centre for reusable templates, delivery profiles, send audit trails, suppressions, replies, and provider events.",
    "surfaces": ["admin", "frontend", "queue"],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/core",
            "capell-app/frontend"
        ],
        "optional": [
            "capell-app/form-builder",
            "capell-app/campaign-studio",
            "capell-app/insights"
        ],
        "conflicts": []
    },
    "lifecycle": {
        "activation": "manual",
        "defaultStatus": "available",
        "requiresInstallCommand": false
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\EmailStudio\\Providers\\EmailStudioServiceProvider"
        ],
        "admin": ["Capell\\EmailStudio\\Providers\\AdminServiceProvider"],
        "frontend": ["Capell\\EmailStudio\\Providers\\FrontendServiceProvider"]
    },
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "setupParams": [],
        "demo": null,
        "demoParams": [],
        "health": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [
        "transactional-email",
        "template-rendering",
        "delivery-audit",
        "suppressions",
        "provider-adapters"
    ],
    "assets": [],
    "healthChecks": []
}
