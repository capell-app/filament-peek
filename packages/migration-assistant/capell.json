{
    "manifest-version": 2,
    "name": "capell-app/migration-assistant",
    "kind": "package",
    "capell-version": "^4.0",
    "productGroup": "Capell Operations",
    "tier": "premium",
    "bundle": "operations",
    "description": "MigrationAssistant provides package import workflows, source reads, mapping, preview, validation, execution state, and rollback reports.",
    "surfaces": ["admin", "console"],
    "dependencies": {
        "requires": ["capell-app/admin", "capell-app/core"],
        "optional": [],
        "conflicts": []
    },
    "lifecycle": {
        "activation": "manual",
        "defaultStatus": "available",
        "requiresInstallCommand": false
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\MigrationAssistant\\Providers\\MigrationAssistantServiceProvider"
        ],
        "admin": [],
        "frontend": []
    },
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "setupParams": [],
        "demo": null,
        "demoParams": [],
        "health": null
    },
    "settings": [],
    "permissions": [
        "page.export",
        "site.export",
        "page.import",
        "site.import",
        "page.import.update-shared-relations",
        "page.import.publish-live",
        "import-session.view",
        "import-session.cancel",
        "import-session.retry"
    ],
    "capabilities": [],
    "assets": [],
    "healthChecks": []
}
