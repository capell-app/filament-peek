{
    "name": "capell-app/seo-suite",
    "description": "SEO tools for Capell (metadata panels, structured data, social meta, AI ai-orchestrator)",
    "keywords": [
        "capell",
        "seo",
        "discoverability",
        "structured-data",
        "ai-orchestrator",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0 || 4.x-dev",
        "capell-app/insights": "^4.0 || 4.x-dev",
        "capell-app/frontend": "^4.0 || 4.x-dev",
        "capell-app/site-discovery": "^4.0 || 4.x-dev",
        "prism-php/prism": "^0.100"
    },
    "suggest": {
        "capell-app/publishing-studio": "Enables workspace-aware SEO publish dashboard-dashboard_reports."
    },
    "require-dev": {
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\SeoSuite\\": "src/",
            "Capell\\SeoSuite\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\SeoSuite\\Providers\\SeoSuiteServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "type": "library",
    "homepage": "https://github.com/capell-app/seo-suite",
    "authors": [
        {
            "name": "Capell Team",
            "email": "team@capell.app",
            "role": "Developer"
        }
    ],
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/seo-suite"
    }
}
