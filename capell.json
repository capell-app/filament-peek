{
    "manifest-version": 3,
    "name": "capell-app/filament-peek",
    "slug": "filament-peek",
    "displayName": "Filament Peek",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Preview unsaved page and Layout Builder edits exactly as they'll render on your live theme — through a private, expiring, signed link, with nothing written to your content until you save.",
    "product": {
        "group": "Capell Foundation",
        "tier": "free",
        "bundle": "foundation"
    },
    "namespace": "Capell\\FilamentPeek",
    "surfaces": [
        "admin",
        "frontend"
    ],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/frontend"
        ],
        "supports": [
            "capell-app/layout-builder",
            "capell-app/publishing-studio"
        ],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\FilamentPeek\\Providers\\FilamentPeekServiceProvider"
        ],
        "admin": [
            "Capell\\FilamentPeek\\Providers\\FilamentPeekServiceProvider"
        ],
        "frontend": [
            "Capell\\FilamentPeek\\Providers\\FilamentPeekServiceProvider"
        ]
    },
    "contributes": [],
    "database": {
        "migrations": false,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [
        "page-preview"
    ],
    "security": {
        "riskTier": "sensitive",
        "publicSurface": {
            "routeNames": [
                "capell-filament-peek.preview",
                "preview"
            ],
            "auth": "signed",
            "csrfExemptRoutes": [],
            "signedRoutes": [
                "preview"
            ],
            "tokenizedRoutes": [
                "capell-filament-peek.preview",
                "preview"
            ],
            "webhookRoutes": [],
            "throttledRoutes": []
        },
        "sensitiveData": {
            "encryptedFields": [],
            "hashedTokenFields": [],
            "redactedOutputClasses": [],
            "plaintextJustifications": []
        },
        "publicOutput": {
            "cacheSafe": false,
            "forbidAuthoringSurface": true,
            "forbidSecrets": true,
            "forbidPublicBladeQueries": true
        },
        "externalHttpClients": {
            "requiresTimeouts": false,
            "requiresSecretRedaction": false,
            "clients": []
        },
        "adminSurface": {
            "authorization": "panel-auth",
            "permissions": []
        }
    },
    "performance": {
        "frontendRenderBudgetMs": 0,
        "adminQueryBudget": 40,
        "cacheTags": [
            "filament-peek-preview"
        ],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": [
                "admin-user",
                "snapshot-token"
            ],
            "sensitiveOutput": true,
            "invalidationSources": [],
            "queueInvalidation": false
        }
    },
    "healthChecks": [
        {
            "key": "filament-peek.package-health",
            "label": "Filament Peek preview routes, actions, and service provider are discoverable.",
            "class": "Capell\\FilamentPeek\\Health\\FilamentPeekHealthCheck",
            "severity": "critical",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "free",
        "requestedCertification": "first-party",
        "supportPolicy": "capell-first-party",
        "privateDocsRequested": false
    },
    "marketplace": {
        "summary": "Preview unsaved page and Layout Builder edits exactly as they'll render on your live theme — through a private, expiring, signed link, with nothing written to your content until you save.",
        "screenshots": [
            {
                "path": "docs/assets/marketplace/extension-card.jpg",
                "alt": "Filament Peek extension preview image",
                "caption": "Filament Peek extension preview"
            },
            {
                "path": "docs/screenshots/page-edit-preview-actions.png",
                "alt": "Capell Page edit screen with the Filament Peek preview action group",
                "caption": "Open the Preview action group from a real Capell Page edit screen before reviewing unsaved changes"
            },
            {
                "path": "docs/screenshots/page-edit-preview-actions-dark.png",
                "alt": "Capell Page edit screen in dark mode with the Filament Peek preview action group",
                "caption": "Use the same unsaved preview action from Capell's dark admin theme"
            }
        ],
        "categories": [
            "admin",
            "editorial"
        ]
    },
    "contributionTraceability": {
        "deferredContributions": [
            "route"
        ]
    }
}
