includes:
    - ./phpstan.common.neon

parameters:
    paths:
        - packages/access-gate/tests
        - packages/address/tests
        - packages/agent-bridge/tests
        - packages/ai-orchestrator/tests
        - packages/blog/tests
        - packages/campaign-studio/tests
        - packages/content-sections/tests
        - packages/dashboard-reports/tests
        - packages/demo-kit/tests
        - packages/deployments/tests
        - packages/diagnostics/tests
        - packages/events/tests
        - packages/form-builder/tests
        - packages/foundation-theme/tests
        - packages/frontend-authoring/tests
        - packages/frontend-optimizer/tests
        - packages/ga4-reports/tests
        - packages/insights/tests
        - packages/login-audit/tests
        - packages/media-ai/tests
        - packages/media-library/tests
        - packages/migration-assistant/tests
        - packages/navigation/tests
        - packages/newsletter/tests
        - packages/password-policy/tests
        - packages/publishing-studio/tests
        - packages/search/tests
        - packages/seo-suite/tests
        - packages/tags/tests
        - packages/theme-agency/tests
        - packages/theme-corporate/tests
        - packages/theme-saas/tests
        - packages/welcome-tour/tests
        - packages/wordpress-importer/tests
        - tests
    tmpDir: /tmp/phpstan/capell-packages-tests
    type_coverage:
        return_type: 0
        param_type: 0
        property_type: 0
        constant_type: 0
