namespace Sinnbeck\DomAssertions\Asserts;

class BaseAssert {}

class AssertElement extends BaseAssert
{
    public function containsAttribute(string $attribute, ?string $value = null): self {}

    public function containsText(string $text): self {}

    public function doesntContain(string $selector): self {}

    public function contains(string $selector, ?int $count = null): self {}

    public function has(string $attribute, string $value): self {}

    /**
     * @param  callable(AssertElement): BaseAssert  $callback
     */
    public function find(string $selector, callable $callback): self {}

    /**
     * @param  callable(AssertElement, int): BaseAssert  $callback
     */
    public function each(string $selector, callable $callback): self {}
}

namespace Spatie\EloquentSortable;

interface Sortable
{
    /**
     * @param  \Illuminate\Database\Eloquent\Builder<\Illuminate\Database\Eloquent\Model>  $query
     * @return \Illuminate\Database\Eloquent\Builder<\Illuminate\Database\Eloquent\Model>
     */
    public function scopeOrdered(\Illuminate\Database\Eloquent\Builder $query): \Illuminate\Database\Eloquent\Builder;
}
