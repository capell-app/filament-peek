{
    "name": "capell-packages-app",
    "scripts": {
        "docs:publish": "cd ../../../capell-docs && CAPELL_PACKAGES_PATH=../packages/capell/capell-packages-4 npm run sync:local:packages && npm run build",
        "screenshots:manifest": "node scripts/build-package-screenshot-manifest.js",
        "screenshots:check": "node scripts/validate-screenshot-manifests.js",
        "screenshots:validate": "node scripts/validate-screenshot-manifests.js",
        "prettier": "npx prettier --write 'packages/**/*.{css,js,yml,json,md,blade.php}'",
        "eslint": "npx eslint 'packages/**/resources/js/**/*.js' --max-warnings=0"
    },
    "devDependencies": {
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "playwright": "^1.60.0",
        "prettier": "^3.5.2",
        "prettier-plugin-blade": "^2.1.21",
        "prettier-plugin-tailwindcss": "^0.6.11"
    }
}
